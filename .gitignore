# Self-provisioned toolchain (uv-managed Python, vendored Node, caches)
.toolchain/

# Python
backend/.venv/
__pycache__/
*.py[cod]
*.egg-info/
backend/*.db
backend/*.db-*
backend/*.db.*
backend/*.backup-*
backend/*.recovered
backend/_migench.db
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Generated / user content + packaging output
backend/covers/
backend/media/
backend/state/
backend/dist-pkg/
dist-pkg/

# Node / frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Playwright
frontend/test-results/
frontend/playwright-report/
frontend/e2e/.auth/

# Env / editor
.env
*.log
.DS_Store
.idea/
.vscode/

# Transient build/test artifacts
**/test-results/
*.tsbuildinfo

# project-root runtime DB (never commit)
/*.db
/*.db-*

# Claude Code local runtime artifacts
.claude/

# Local-only operational artifacts (one-off repair scripts, restore staging, review notes)
/backend/backups/
/backend/relink_library.py
/backend/shelf.db.bak-*
/backend/shelf.db.pre-*
# Scratch review / implementation notes — kept locally, never committed
/fix_issues.txt
/fix_implementation.txt
/IMPLEMENTATION_REPORT.txt
/REVIEW_*.txt
/bugs*review*.txt
/*_REPORT.txt
/staging_*
/.ui-review/

# Local-only maintenance/restore/cleanup artifacts + UI-review screenshots — NEVER commit (data or junk)
backend/restore_*.py
backend/cleanup_*.py
backend/*_restore.json
backend/*_undo*.json
.ui-review-*/
backend/.ui-review-*/
