# Shelf configuration — copy to `backend/.env` and edit, or set as SHELF_* env vars.
# This file is a TEMPLATE: it contains NO secrets. Never commit your real `.env`.
# Most operational settings are also editable at runtime in Settings → System (no restart);
# the values here are the boot/built-in defaults. Anything you don't set uses the default.

# ── Core ────────────────────────────────────────────────────────────────────
SHELF_APP_NAME=Shelf
# SQLAlchemy URL. Default is a local SQLite file next to the backend.
SHELF_DATABASE_URL=sqlite:///./shelf.db
SHELF_LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# ── Network / serving ───────────────────────────────────────────────────────
SHELF_HOST=0.0.0.0
SHELF_PORT=8000
# Comma-separated host allow-list ("*" = any). Set to your domain in production.
SHELF_ALLOWED_HOSTS=*
# CORS origins for the Vite dev server (comma-separated or JSON array).
SHELF_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Storage paths (blank = sensible defaults under the backend dir) ──────────
# Also configurable in Settings → Storage (a runtime override there wins over these env defaults).
#
# RECOMMENDED LAYOUT for a self-host with a large NAS/pool: put the bulky, re-buildable data on the
# pool and keep only the small hot cover cache + the DB on the app's local disk. This stops the local
# disk filling up with a "shadow" copy of everything the crawler/ingester touches:
#   • MEDIA_DIR / BACKUP_DIR / STOCK_DIR / AUDIOBOOK_DIR → the NAS/pool (big, re-fetchable or archival)
#   • COVERS_DIR → leave BLANK = local disk (durable, never-evicted, auto-compressed thumbnails)
# e.g.:
#   SHELF_MEDIA_DIR=/mnt/pool/media/.app-media       # imgcache + comic pages + book media (rebuildable)
#   SHELF_BACKUP_DIR=/mnt/pool/media/.app-backups     # instance backup zips
#   SHELF_STOCK_DIR=/mnt/pool/media/Books             # ebook/comic downloads land here
#   SHELF_AUDIOBOOK_DIR=/mnt/pool/media/Audiobooks    # audiobook library
SHELF_MEDIA_DIR=
SHELF_COVERS_DIR=
SHELF_BACKUP_DIR=
SHELF_STOCK_DIR=
SHELF_AUDIOBOOK_DIR=
SHELF_STATIC_DIR=
SHELF_IMGCACHE_MAX_MB=40960                # LRU cap (MB) for the (re-fetchable) image cache
# Content languages to stock + search metadata for (comma-separated ISO codes; blank/"*" = any).
# Default "en"; add more for multilingual libraries, e.g. "en,no" for English + Norwegian.
SHELF_CONTENT_LANGUAGES=en

# ── Auth / sessions / security ──────────────────────────────────────────────
SHELF_SESSION_DAYS=30
SHELF_COOKIE_SECURE=false                  # true behind HTTPS (set by tunnel mode)
SHELF_COOKIE_SAMESITE=lax                  # lax | strict | none
SHELF_TRUST_PROXY=false                    # true when behind a reverse proxy
SHELF_FORWARDED_ALLOW_IPS=127.0.0.1
SHELF_LOGIN_MAX_ATTEMPTS=6
SHELF_LOGIN_WINDOW_SECONDS=900             # lockout window for failed logins
SHELF_MIN_PASSWORD_LENGTH=8
# Required to create the FIRST admin over a public (non-localhost) connection.
# Leave blank for localhost setup; set a random token before exposing the app.
SHELF_SETUP_TOKEN=
SHELF_ENABLE_DOCS=false                    # expose /docs + /openapi.json (off in prod)
SHELF_SECURITY_HEADERS=true
SHELF_HSTS=true                            # only emitted over https

# ── Crawl identity & politeness (also editable in Settings → Crawl identity) ─
SHELF_USER_AGENT=
SHELF_CONTACT_EMAIL=operator@localhost
SHELF_GLOBAL_MAX_CONCURRENCY=16
SHELF_DEFAULT_MIN_REQUEST_INTERVAL_S=5.0

# ── Index crawl defaults (Settings → Crawl defaults) ────────────────────────
SHELF_INDEX_MAX_PAGES=0                     # 0 = unlimited
SHELF_INDEX_MAX_DEPTH=50
SHELF_INDEX_STOP_AFTER_IDLE_PAGES=200
SHELF_INDEX_MAX_PENDING_FRONTIER=50000

# ── Cloudflare solver (optional; Settings → System) ─────────────────────────
SHELF_FLARESOLVERR_URL=                     # e.g. http://host:8191 (blank = use in-app browser)
SHELF_FLARESOLVERR_TIMEOUT_S=60
SHELF_FLARESOLVERR_CLEARANCE_TTL_S=1500
SHELF_SOLVER_CHROME_PATH=                   # blank = auto-detect bundled Chromium

# ── Scheduler ───────────────────────────────────────────────────────────────
SHELF_SCHEDULER_ENABLED=true
SHELF_SCHEDULER_TICK_SECONDS=15
SHELF_CHAPTERS_PER_TICK=1

# ── Automatic backups (Settings → System) ───────────────────────────────────
SHELF_AUTO_BACKUP_ENABLED=true
SHELF_AUTO_BACKUP_LEVEL=data                # settings | data | full
SHELF_AUTO_BACKUP_INTERVAL_HOURS=24
SHELF_AUTO_BACKUP_KEEP=7

# ── Send-to-Kindle / email (or configure in Settings → Send to Kindle) ──────
# Leave SHELF_SMTP_HOST blank to disable server-side email delivery.
SHELF_SMTP_HOST=
SHELF_SMTP_PORT=587
SHELF_SMTP_USER=
SHELF_SMTP_PASSWORD=                        # SECRET — do not commit a real value
SHELF_SMTP_FROM=
SHELF_SMTP_STARTTLS=true
SHELF_SMTP_SSL=false
